#!/usr/bin/env bash
# toolboxer — drop-in replacement for `toolbox` that only mounts selected directories (restricted)

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

# Detect host distro and version for the default image. ID_LIKE lets us map
# derivatives (Mint, Pop!_OS, Manjaro, …) onto their base distro's image.
HOST_ID="fedora"
HOST_VERSION_ID="latest"
HOST_ID_LIKE=""
if [[ -f /etc/os-release ]]; then
    source /etc/os-release
    HOST_ID="${ID:-fedora}"
    HOST_VERSION_ID="${VERSION_ID:-latest}"
    HOST_ID_LIKE="${ID_LIKE:-}"
fi

DEFAULT_MOUNT_DIRS="${HOME}/code"

# Resolve the container image from distro + release.
#
# Known distros map to their official toolbox/base image at the host's release.
# A distro we don't recognise directly is mapped to a base via its os-release
# ID_LIKE (resolve_image_from_like): derivatives such as Mint/Pop!_OS/Manjaro
# go to their parent, and any RHEL-family clone (Rocky, AlmaLinux, Oracle, …)
# defaults to Rocky Linux — a binary-compatible image, unlike Fedora. Anything
# still unrecognised falls back to Fedora's toolbox image.
resolve_image() {
    local distro="${1:-$HOST_ID}"
    local release="${2:-$HOST_VERSION_ID}"
    case "$distro" in
        fedora)              echo "registry.fedoraproject.org/fedora-toolbox:${release}" ;;
        rhel)                echo "registry.access.redhat.com/ubi${release%%.*}/toolbox:${release}" ;;
        centos)              echo "quay.io/centos/centos:stream${release%%.*}" ;;
        rocky)               echo "docker.io/library/rockylinux:${release%%.*}" ;;
        ubuntu)              echo "docker.io/library/ubuntu:${release}" ;;
        debian)              echo "docker.io/library/debian:${release%%.*}" ;;
        arch)                echo "docker.io/library/archlinux:latest" ;;
        opensuse-leap)       echo "registry.opensuse.org/opensuse/leap:${release}" ;;
        opensuse-tumbleweed) echo "registry.opensuse.org/opensuse/tumbleweed:latest" ;;
        *)                   resolve_image_from_like "$release" ;;
    esac
}

# Map a distro we don't handle directly to a base image via os-release ID_LIKE.
# Non-RHEL derivative versions rarely line up with the base's tags, so those are
# pulled at :latest; RHEL-family clones share RHEL's major versioning, so they
# map to Rocky Linux at the host's major version. Falls back to Fedora's toolbox
# image when ID_LIKE is empty or names nothing we recognise.
resolve_image_from_like() {
    local release="${1:-latest}"
    local like
    for like in $HOST_ID_LIKE; do
        case "$like" in
            ubuntu)        echo "docker.io/library/ubuntu:latest";                  return ;;
            debian)        echo "docker.io/library/debian:latest";                  return ;;
            arch)          echo "docker.io/library/archlinux:latest";               return ;;
            suse|opensuse) echo "registry.opensuse.org/opensuse/tumbleweed:latest"; return ;;
            rhel|centos)   echo "docker.io/library/rockylinux:${release%%.*}";      return ;;
            fedora)        echo "registry.fedoraproject.org/fedora-toolbox:latest"; return ;;
        esac
    done
    echo "registry.fedoraproject.org/fedora-toolbox:latest"
}

# Resolve the default container name from distro + release
resolve_name() {
    local distro="${1:-$HOST_ID}"
    local release="${2:-$HOST_VERSION_ID}"
    echo "${distro}-toolbox-${release}"
}

# Overridable via env vars (CLI flags take precedence). Inherit env values
# here — `=""` would silently clobber what the user exported.
MOUNT_DIRS="${MOUNT_DIRS:-$DEFAULT_MOUNT_DIRS}"
CONTAINER_NAME="${CONTAINER_NAME:-}"
IMAGE="${IMAGE:-}"

# These will be set after flag parsing
DISTRO=""
RELEASE=""

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    local prog
    prog="$(basename "$0")"
    cat <<EOF
toolboxer — a restricted, drop-in replacement for toolbox.

Usage: $prog [global options] <command> [command options] [args...]

Creates Podman development containers that mount only the directories you
choose, instead of your entire home directory:
  * Only selected directories are mounted (read-write)
  * Host integration (X11, Wayland, D-Bus, SSH agent, DNS, etc.) is seamless
  * A matching user with passwordless sudo is created inside the container
  * Uses --userns=keep-id so your UID/GID stay the same inside

Running '$prog' with no command defaults to 'enter'.

Commands:
  create [CONTAINER]      Create the container
  enter  [CONTAINER]      Enter the container (starts it if stopped, offers to create)
  run <cmd> [args...]     Run a single command inside the container
  list                    List toolboxer containers and/or images
  stop   [CONTAINER]      Stop the container
  rm     [CONTAINER...]   Remove the container(s)
  rmi    <IMAGE...>       Remove toolboxer image(s)
  help                    Show this help

Global options (must come before the command):
  -m, --mount DIR         Mount DIR (read-write) into the container. Repeat the
                          flag once per directory. This replaces the default
                          mount ($DEFAULT_MOUNT_DIRS) rather than adding to it.
  -h, --help              Show this help

Each command has its own options too — see '$prog <command> --help'.

Mounting additional directories:
  By default only $DEFAULT_MOUNT_DIRS is mounted. Pass -m/--mount once per
  directory you want available inside the container (the first one becomes the
  working directory on 'enter'):

    $prog -m ~/code -m ~/documents create
    $prog create -m ~/code -m ~/work/project   # 'create' accepts -m directly too

  Or set MOUNT_DIRS to a colon-separated list (CLI flags override it):

    MOUNT_DIRS=~/code:~/documents $prog create

Environment variables (lowest priority — CLI flags override these):
  CONTAINER_NAME          Default container name
  IMAGE                   Image to use (e.g. fedora:41)
  MOUNT_DIRS              Colon-separated list of directories to mount

Examples:
  $prog                                # enter the default container
  $prog create                         # create the default container
  $prog -m ~/code -m ~/docs create     # create, mounting two directories
  $prog create --distro ubuntu --release 24.04
  $prog create --image fedora:41 my-project
  $prog enter my-project               # enter a named container
  $prog run make test                  # run a command in the container
  $prog list --containers              # list only containers
  $prog rm --all --force               # remove every toolboxer container
EOF
    exit "${1:-1}"
}

usage_create() {
    local prog
    prog="$(basename "$0")"
    cat <<EOF
Usage: $prog create [options] [CONTAINER]

Create a new toolboxer container. If CONTAINER is omitted, the name is derived
from the distro and release (e.g. ${HOST_ID}-toolbox-${HOST_VERSION_ID}).

Options:
  -d, --distro DISTRO   Base distro: fedora, rhel, centos, rocky, ubuntu, debian,
                        arch, opensuse-leap, opensuse-tumbleweed
                        (default: host distro, $HOST_ID; incompatible with --image)
  -r, --release RELEASE Distro release/version
                        (default: host release, $HOST_VERSION_ID; incompatible with --image)
  -i, --image NAME      Use a custom image (incompatible with --distro/--release)
  -m, --mount DIR       Mount DIR (read-write); repeat once per directory.
                        Replaces the default mount ($DEFAULT_MOUNT_DIRS).
                        The first mounted directory becomes the working directory.
  -h, --help            Show this help

Examples:
  $prog create
  $prog create -m ~/code -m ~/documents
  $prog create --distro ubuntu --release 24.04 ubuntu-dev
  $prog create --image fedora:41
EOF
    exit "${1:-1}"
}

usage_enter() {
    local prog
    prog="$(basename "$0")"
    cat <<EOF
Usage: $prog enter [options] [CONTAINER]

Enter a toolboxer container, starting it if stopped. If no container is named,
the default is used; if exactly one toolboxer container exists, it is chosen
automatically. If none exist, you are offered the chance to create one.

To mount extra directories when creating on demand, pass -m/--mount as a global
option before 'enter' (e.g. '$prog -m ~/code enter').

Options:
  -d, --distro DISTRO   Enter the container for a different distro
                        (fedora, rhel, centos, rocky, ubuntu, debian, arch, opensuse-*)
  -r, --release RELEASE Enter the container for a different release
  -h, --help            Show this help

Examples:
  $prog enter
  $prog enter my-project
  $prog enter --distro ubuntu --release 24.04
EOF
    exit "${1:-1}"
}

usage_run() {
    local prog
    prog="$(basename "$0")"
    cat <<EOF
Usage: $prog run [options] [--] COMMAND [ARGS...]

Run a single command inside a toolboxer container, then exit. The container is
started first if it is stopped. Use '--' before COMMAND if its arguments would
otherwise be mistaken for run's own options.

Options:
  -c, --container NAME  Run in a specific container (default: the resolved container)
  -d, --distro DISTRO   Run in the container for a different distro
                        (fedora, rhel, centos, rocky, ubuntu, debian, arch, opensuse-*)
  -r, --release RELEASE Run in the container for a different release
  -h, --help            Show this help

Examples:
  $prog run make test
  $prog run --container my-project gcc -o hello hello.c
  $prog run -- ls -la
EOF
    exit "${1:-1}"
}

usage_list() {
    local prog
    prog="$(basename "$0")"
    cat <<EOF
Usage: $prog list [options]

List toolboxer containers and images. With no options, both are shown.

Options:
  -c, --containers      Show only containers
  -i, --images          Show only images
  -h, --help            Show this help

Examples:
  $prog list
  $prog list --containers
  $prog list --images
EOF
    exit "${1:-1}"
}

usage_rm() {
    local prog
    prog="$(basename "$0")"
    cat <<EOF
Usage: $prog rm [options] [CONTAINER...]

Remove one or more toolboxer containers. With no names and no --all, the
container is resolved the same way as 'create' — from --distro/--release (or
the host defaults) — so you can remove a container without typing its full
name. Running containers need --force.

Options:
  -a, --all             Remove all toolboxer containers
  -f, --force           Force removal of running containers
  -d, --distro DISTRO   Remove the container for a different distro
  -r, --release RELEASE Remove the container for a different release
  -h, --help            Show this help

Examples:
  $prog rm
  $prog rm my-project another-project
  $prog rm -r 44                  # removes the fedora-toolbox-44 container
  $prog rm --all --force
EOF
    exit "${1:-1}"
}

usage_rmi() {
    local prog
    prog="$(basename "$0")"
    cat <<EOF
Usage: $prog rmi [options] <IMAGE...>

Remove one or more toolbox images. Specify image name(s) or use --all.

Options:
  -a, --all             Remove all toolbox images
  -f, --force           Force removal (removes dependent containers too)
  -h, --help            Show this help

Examples:
  $prog rmi fedora-toolbox:41
  $prog rmi --all
  $prog rmi --all --force
EOF
    exit "${1:-1}"
}

usage_stop() {
    local prog
    prog="$(basename "$0")"
    cat <<EOF
Usage: $prog stop [options] [CONTAINER]

Stop a running toolboxer container. If no container is named, it is resolved
from --distro/--release (or the host defaults); if none of those match and only
one toolboxer container exists, that one is stopped.

Options:
  -d, --distro DISTRO   Stop the container for a different distro
  -r, --release RELEASE Stop the container for a different release
  -h, --help            Show this help

Examples:
  $prog stop
  $prog stop my-project
  $prog stop -r 44                # stops the fedora-toolbox-44 container
EOF
    exit "${1:-1}"
}

# ---------------------------------------------------------------------------
# Parse global options (only -m/--mount and -h/--help before the command)
# ---------------------------------------------------------------------------

cli_mounts=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -m|--mount) cli_mounts+=("$2");  shift 2 ;;
        -h|--help)  usage 0 ;;
        -*)         echo "Unknown option: $1"; usage ;;
        *)          break ;;
    esac
done

if [[ ${#cli_mounts[@]} -gt 0 ]]; then
    MOUNT_DIRS=""
    for d in "${cli_mounts[@]}"; do
        MOUNT_DIRS="${MOUNT_DIRS:+$MOUNT_DIRS:}$d"
    done
fi

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

read_mount_dirs() {
    local IFS=":"
    read -ra _MOUNT_ARRAY <<< "$MOUNT_DIRS"
}

build_volume_args() {
    read_mount_dirs
    local args=()
    for d in "${_MOUNT_ARRAY[@]}"; do
        mkdir -p "$d"
        args+=(--volume "$d:$d:z")
    done
    printf '%s\n' "${args[@]}"
}

build_host_integration_args() {
    local args=()

    local -a host_configs=(
        /etc/resolv.conf
        /etc/hosts
        /etc/host.conf
        /etc/hostname
        /etc/localtime
        /etc/timezone
        /etc/machine-id
    )
    for f in "${host_configs[@]}"; do
        [[ -e "$f" ]] && args+=(--volume "$f:$f:ro")
    done

    if [[ -d /tmp/.X11-unix ]]; then
        args+=(--volume "/tmp/.X11-unix:/tmp/.X11-unix:ro")
    fi

    local xdg_runtime="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    if [[ -d "$xdg_runtime" ]]; then
        args+=(--volume "$xdg_runtime:$xdg_runtime")
    fi

    if [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
        local dbus_path="${DBUS_SESSION_BUS_ADDRESS#unix:path=}"
        if [[ "$dbus_path" != "$DBUS_SESSION_BUS_ADDRESS" && -e "$dbus_path" ]]; then
            args+=(--volume "$dbus_path:$dbus_path")
        fi
    fi

    if [[ -n "${SSH_AUTH_SOCK:-}" && -e "$SSH_AUTH_SOCK" ]]; then
        args+=(--volume "$SSH_AUTH_SOCK:$SSH_AUTH_SOCK")
    fi

    if [[ -d /run/systemd/journal ]]; then
        args+=(--volume "/run/systemd/journal:/run/systemd/journal:ro")
    fi

    if [[ -d /run/udev/data ]]; then
        args+=(--volume "/run/udev/data:/run/udev/data:ro")
    fi

    printf '%s\n' "${args[@]}"
}

build_env_args() {
    local args=()

    [[ -n "${DISPLAY:-}" ]]                && args+=(--env "DISPLAY=$DISPLAY")
    [[ -n "${WAYLAND_DISPLAY:-}" ]]        && args+=(--env "WAYLAND_DISPLAY=$WAYLAND_DISPLAY")
    [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]] && args+=(--env "DBUS_SESSION_BUS_ADDRESS=$DBUS_SESSION_BUS_ADDRESS")
    [[ -n "${SSH_AUTH_SOCK:-}" ]]          && args+=(--env "SSH_AUTH_SOCK=$SSH_AUTH_SOCK")
    [[ -n "${TERM:-}" ]]                   && args+=(--env "TERM=$TERM")
    [[ -n "${LANG:-}" ]]                   && args+=(--env "LANG=$LANG")

    local xdg_runtime="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    args+=(--env "XDG_RUNTIME_DIR=$xdg_runtime")

    printf '%s\n' "${args[@]}"
}

# Devices needed to run rootless podman/buildah *inside* the container
# (podman-in-podman):
#   * /dev/fuse    — fuse-overlayfs storage driver for the nested podman
#   * /dev/net/tun — the pasta/slirp4netns rootless network backend
# Each is only passed through if present on the host, so hosts without them
# (e.g. /dev/net/tun when the tun module isn't loaded) still create cleanly.
build_device_args() {
    local args=()
    local -a nested_devices=(
        /dev/fuse
        /dev/net/tun
    )
    for dev in "${nested_devices[@]}"; do
        [[ -e "$dev" ]] && args+=(--device "$dev")
    done
    # Emit nothing when empty — a blank line would become a spurious empty
    # argument to `podman create`.
    [[ ${#args[@]} -gt 0 ]] && printf '%s\n' "${args[@]}"
}

default_workdir() {
    read_mount_dirs
    echo "${_MOUNT_ARRAY[0]}"
}

setup_user_in_container() {
    local cname="$1"
    local uid gid user_name user_shell user_home
    uid="$(id -u)"
    gid="$(id -g)"
    user_name="$(id -un)"
    # The host's login shell isn't guaranteed to exist in the container, so
    # default to bash (always present in toolbox-style images).
    user_shell="/bin/bash"
    user_home="$HOME"

    # Create group and user (as root inside the container)
    podman exec --user root "$cname" bash -c "getent group $gid >/dev/null 2>&1 || groupadd -g $gid $user_name"
    podman exec --user root "$cname" bash -c "id $user_name >/dev/null 2>&1 || useradd -u $uid -g $gid -d $user_home -s $user_shell -M $user_name" 2>/dev/null || true

    # Ensure sudo is installed — Fedora/RHEL toolbox images ship it, but the
    # generic ubuntu/arch images we support via --distro don't.
    podman exec --user root "$cname" bash -c '
        if command -v sudo >/dev/null 2>&1; then exit 0; fi
        if command -v dnf >/dev/null 2>&1; then
            dnf install -y sudo >/dev/null 2>&1
        elif command -v apt-get >/dev/null 2>&1; then
            apt-get update >/dev/null 2>&1 && DEBIAN_FRONTEND=noninteractive apt-get install -y sudo >/dev/null 2>&1
        elif command -v pacman >/dev/null 2>&1; then
            pacman -Sy --noconfirm sudo >/dev/null 2>&1
        fi
    ' || true

    # Grant passwordless sudo
    podman exec --user root "$cname" mkdir -p /etc/sudoers.d
    podman exec --user root "$cname" bash -c "echo '$user_name ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/$user_name && chmod 440 /etc/sudoers.d/$user_name"

    # Make rootless podman-in-podman work with the fewest host requirements:
    # default the *nested* podman to host networking, so it needs no
    # /dev/net/tun (pasta/slirp4netns) on the host. Storage falls back to
    # native overlay on modern kernels, so /dev/fuse isn't required either.
    # (A drop-in is used so it merges with, rather than replaces, the image's
    # own containers.conf. Harmless when podman isn't installed.)
    podman exec --user root "$cname" bash -c '
        mkdir -p /etc/containers/containers.conf.d
        cat > /etc/containers/containers.conf.d/90-toolboxer-nested.conf <<EOF
# Added by toolboxer: host networking for nested (podman-in-podman) containers
# so no /dev/net/tun is needed. Override per-container with e.g. --network pasta.
[containers]
netns="host"
EOF
    ' || true
}

ensure_exists() {
    podman container exists "$CONTAINER_NAME"
}

ensure_started() {
    local state
    state="$(podman inspect --format '{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || true)"

    if [[ "$state" == "running" ]]; then
        return 0
    fi

    # Container is created/stopped — start it
    podman start "$CONTAINER_NAME" >/dev/null 2>&1

    # Run user setup on first start (check if sudoers file exists)
    local user_name
    user_name="$(id -un)"
    if ! podman exec --user root "$CONTAINER_NAME" test -f "/etc/sudoers.d/$user_name" 2>/dev/null; then
        echo "Setting up user environment..."
        setup_user_in_container "$CONTAINER_NAME"
    fi
}

# Find the default container: use CONTAINER_NAME if set/exists, otherwise
# fall back to the only existing toolboxer container (if exactly one exists).
resolve_container() {
    if [[ -n "$CONTAINER_NAME" ]] && ensure_exists; then
        return 0
    fi

    local containers
    containers="$(podman container list --all --filter 'label=toolboxer=true' --format '{{.Names}}' 2>/dev/null)"
    local count
    count="$(echo "$containers" | grep -c . 2>/dev/null || true)"

    if [[ "$count" -eq 1 ]]; then
        CONTAINER_NAME="$containers"
        echo "Using container '$CONTAINER_NAME'"
        return 0
    fi

    return 1
}

# Finalize CONTAINER_NAME and IMAGE from distro/release/env/defaults.
# CONTAINER_NAME/IMAGE are pre-seeded from the environment at the top of the
# script, so anything still empty here means: no CLI flag, no env value — use
# the distro/release default.
finalize_names() {
    if [[ -z "$CONTAINER_NAME" ]]; then
        CONTAINER_NAME="$(resolve_name "$DISTRO" "$RELEASE")"
    fi
    if [[ -z "$IMAGE" ]]; then
        IMAGE="$(resolve_image "$DISTRO" "$RELEASE")"
    fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd="${1:-}"
if [[ -z "$cmd" ]]; then
    cmd="enter"
else
    shift || true
fi

case "$cmd" in
    create)
        # Parse create-specific flags
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -d|--distro)  DISTRO="$2";  shift 2 ;;
                -i|--image)   IMAGE="$2";   shift 2 ;;
                -r|--release) RELEASE="$2"; shift 2 ;;
                -m|--mount)   cli_mounts+=("$2"); shift 2 ;;
                -h|--help)    usage_create 0 ;;
                -*)           echo "Unknown create option: $1"; usage_create ;;
                *)            CONTAINER_NAME="$1"; shift ;;
            esac
        done

        # --image is incompatible with --distro/--release
        if [[ -n "$IMAGE" && ( -n "$DISTRO" || -n "$RELEASE" ) ]]; then
            echo "Error: --image is incompatible with --distro and --release"
            exit 1
        fi

        # Re-process mounts if any were added in subcommand parsing
        if [[ ${#cli_mounts[@]} -gt 0 ]]; then
            MOUNT_DIRS=""
            for d in "${cli_mounts[@]}"; do
                MOUNT_DIRS="${MOUNT_DIRS:+$MOUNT_DIRS:}$d"
            done
        fi

        finalize_names

        if ensure_exists; then
            echo "Error: Container '$CONTAINER_NAME' already exists."
            echo "Remove it first with: $(basename "$0") rm"
            exit 1
        fi

        read_mount_dirs
        echo "Creating restricted toolbox '$CONTAINER_NAME'"
        echo "Image: $IMAGE"
        echo "Mounting: ${_MOUNT_ARRAY[*]}"

        mapfile -t vol_args < <(build_volume_args)
        mapfile -t host_args < <(build_host_integration_args)
        mapfile -t env_args < <(build_env_args)
        mapfile -t device_args < <(build_device_args)

        podman create -it \
            --name "$CONTAINER_NAME" \
            --userns=keep-id \
            --security-opt label=disable \
            --hostname toolboxer \
            --network host \
            --ipc host \
            --pid host \
            "${vol_args[@]}" \
            "${host_args[@]}" \
            "${env_args[@]}" \
            "${device_args[@]}" \
            --workdir "$(default_workdir)" \
            --label "toolbox=true" \
            --label "toolboxer=true" \
            "$IMAGE" \
            sleep infinity

        echo "Restricted toolbox '$CONTAINER_NAME' created!"
        echo "Run '$(basename "$0") enter' to start using it."
        ;;

    enter)
        # Parse enter-specific flags
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -d|--distro)  DISTRO="$2";  shift 2 ;;
                -r|--release) RELEASE="$2"; shift 2 ;;
                -h|--help)    usage_enter 0 ;;
                -*)           echo "Unknown enter option: $1"; usage_enter ;;
                *)            CONTAINER_NAME="$1"; shift ;;
            esac
        done

        finalize_names

        if ! resolve_container; then
            echo "No toolboxer container found."
            read -rp "Create container '$CONTAINER_NAME' now? [y/N] " answer
            if [[ "$answer" =~ ^[Yy] ]]; then
                # Build the re-invocation as an array so paths with spaces survive.
                reinvoke_args=()
                for d in "${cli_mounts[@]}"; do
                    reinvoke_args+=(-m "$d")
                done
                reinvoke_args+=(create)
                [[ -n "$DISTRO" ]] && reinvoke_args+=(--distro "$DISTRO")
                [[ -n "$RELEASE" ]] && reinvoke_args+=(--release "$RELEASE")
                reinvoke_args+=("$CONTAINER_NAME")
                "$0" "${reinvoke_args[@]}"
            else
                exit 1
            fi
        fi

        ensure_started
        exec podman exec -it \
            --user "$(id -u):$(id -g)" \
            --workdir "$(default_workdir)" \
            "$CONTAINER_NAME" \
            bash -l
        ;;

    run)
        # Parse run-specific flags
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--container) CONTAINER_NAME="$2"; shift 2 ;;
                -d|--distro)    DISTRO="$2";         shift 2 ;;
                -r|--release)   RELEASE="$2";        shift 2 ;;
                -h|--help)      usage_run 0 ;;
                --)             shift; break ;;
                *)              break ;;
            esac
        done

        if [[ $# -eq 0 ]]; then
            echo "Error: 'run' requires a command."
            echo "Usage: $(basename "$0") run <command> [args...]"
            exit 1
        fi

        finalize_names

        if ! resolve_container; then
            echo "Error: No toolboxer container found."
            echo "Create one first with: $(basename "$0") create"
            exit 1
        fi
        ensure_started
        podman exec -it \
            --user "$(id -u):$(id -g)" \
            --workdir "$(default_workdir)" \
            "$CONTAINER_NAME" \
            "$@"
        ;;

    list)
        local_show_containers=true
        local_show_images=true
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--containers) local_show_images=false;     shift ;;
                -i|--images)     local_show_containers=false; shift ;;
                -h|--help)       usage_list 0 ;;
                *) echo "Unknown list option: $1"; usage_list ;;
            esac
        done

        if [[ "$local_show_images" == true ]]; then
            printf "%-14s %-45s %s\n" "IMAGE ID" "IMAGE NAME" "CREATED"
            while IFS=$'\t' read -r iid iname icreated; do
                printf "%-14s %-45s %s\n" "$iid" "$iname" "$icreated"
            done < <(podman image list --filter "reference=*toolbox*" --sort repository --format "{{.ID}}"$'\t'"{{.Repository}}:{{.Tag}}"$'\t'"{{.Created}}")
            echo
        fi
        if [[ "$local_show_containers" == true ]]; then
            printf "%-14s %-25s %-20s %-15s %s\n" "CONTAINER ID" "CONTAINER NAME" "CREATED" "STATUS" "IMAGE NAME"
            while IFS=$'\t' read -r cid cname ccreated cstatus cimage; do
                if [[ "$cstatus" == Up* ]] && [[ -t 1 ]]; then
                    printf "\033[32m%-14s %-25s %-20s %-15s %s\033[0m\n" "$cid" "$cname" "$ccreated" "$cstatus" "$cimage"
                else
                    printf "%-14s %-25s %-20s %-15s %s\n" "$cid" "$cname" "$ccreated" "$cstatus" "$cimage"
                fi
            done < <(podman container list --all --filter "label=toolboxer=true" --format "{{.ID}}\t{{.Names}}\t{{.CreatedHuman}}\t{{.Status}}\t{{.Image}}")
        fi
        ;;

    stop)
        # Parse stop-specific flags / positional container name
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -d|--distro)  DISTRO="$2";  shift 2 ;;
                -r|--release) RELEASE="$2"; shift 2 ;;
                -h|--help)    usage_stop 0 ;;
                -*)           echo "Unknown stop option: $1"; usage_stop ;;
                *)            CONTAINER_NAME="$1"; shift ;;
            esac
        done

        finalize_names

        if ! resolve_container; then
            echo "Error: Container '$CONTAINER_NAME' does not exist."
            exit 1
        fi
        podman stop "$CONTAINER_NAME" && echo "Container '$CONTAINER_NAME' stopped."
        ;;

    rm)
        local_all=false
        local_force=false
        local_containers=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -a|--all)     local_all=true;             shift ;;
                -f|--force)   local_force=true;           shift ;;
                -d|--distro)  DISTRO="$2";                shift 2 ;;
                -r|--release) RELEASE="$2";               shift 2 ;;
                -h|--help)    usage_rm 0 ;;
                -*)           echo "Unknown rm option: $1"; usage_rm ;;
                *)            local_containers+=("$1");   shift ;;
            esac
        done

        rm_flags=()
        [[ "$local_force" == true ]] && rm_flags+=(-f)

        if [[ "$local_all" == true ]]; then
            containers="$(podman container list --all --filter 'label=toolboxer=true' --format '{{.Names}}' 2>/dev/null)"
            if [[ -z "$containers" ]]; then
                echo "No toolboxer containers found."
                exit 0
            fi
            while IFS= read -r c; do
                if podman rm "${rm_flags[@]}" "$c" >/dev/null 2>&1; then
                    echo "Container '$c' removed."
                else
                    echo "Error: Could not remove '$c' (is it running? use --force)"
                fi
            done <<< "$containers"
        else
            # If specific containers were named, use those; otherwise use default
            if [[ ${#local_containers[@]} -eq 0 ]]; then
                finalize_names
                local_containers=("$CONTAINER_NAME")
            fi
            for cname in "${local_containers[@]}"; do
                if podman rm "${rm_flags[@]}" "$cname" >/dev/null 2>&1; then
                    echo "Container '$cname' removed."
                else
                    if podman container exists "$cname"; then
                        echo "Error: Could not remove '$cname' (is it running? use --force)"
                    else
                        echo "Container '$cname' not found."
                    fi
                fi
            done
        fi
        ;;

    rmi)
        local_all=false
        local_force=false
        local_images=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -a|--all)   local_all=true;          shift ;;
                -f|--force) local_force=true;         shift ;;
                -h|--help)  usage_rmi 0 ;;
                -*)         echo "Unknown rmi option: $1"; usage_rmi ;;
                *)          local_images+=("$1");     shift ;;
            esac
        done

        rmi_flags=()
        [[ "$local_force" == true ]] && rmi_flags+=(-f)

        if [[ "$local_all" == true ]]; then
            images="$(podman image list --filter 'reference=*toolbox*' --format '{{.Repository}}:{{.Tag}}' 2>/dev/null)"
            if [[ -z "$images" ]]; then
                echo "No toolbox images found."
                exit 0
            fi
            while IFS= read -r img; do
                if [[ "$local_force" == true ]]; then
                    deps="$(podman container list --all --filter "ancestor=$img" --filter 'label=toolboxer=true' --format '{{.Names}}' 2>/dev/null)"
                    if [[ -n "$deps" ]]; then
                        while IFS= read -r c; do
                            podman rm -f "$c" >/dev/null 2>&1 && echo "Container '$c' removed."
                        done <<< "$deps"
                    fi
                fi
                if podman rmi "${rmi_flags[@]}" "$img" >/dev/null 2>&1; then
                    echo "Image '$img' removed."
                else
                    echo "Error: Could not remove image '$img'"
                fi
            done <<< "$images"
        elif [[ ${#local_images[@]} -gt 0 ]]; then
            for img in "${local_images[@]}"; do
                if podman rmi "${rmi_flags[@]}" "$img" >/dev/null 2>&1; then
                    echo "Image '$img' removed."
                else
                    echo "Error: Could not remove image '$img'"
                fi
            done
        else
            echo "Error: Specify image name(s) or use --all"
            exit 1
        fi
        ;;

    help)
        usage 0
        ;;

    *)
        echo "Unknown command: $cmd"
        usage
        ;;
esac
