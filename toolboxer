#!/usr/bin/env bash
# toolboxer — drop-in replacement for `toolbox` that only mounts selected directories (restricted)

set -euo pipefail

prog="$(basename "$0")"

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

# Detect host distro and version for the default image. ID_LIKE lets us map
# derivatives (Mint, Pop!_OS, Manjaro, …) onto their base distro's image.
HOST_ID="fedora"
HOST_VERSION_ID="latest"
HOST_ID_LIKE=""
if [[ -f /etc/os-release ]]; then
    # shellcheck source=/dev/null
    source /etc/os-release
    HOST_ID="${ID:-fedora}"
    HOST_VERSION_ID="${VERSION_ID:-latest}"
    HOST_ID_LIKE="${ID_LIKE:-}"
fi

DEFAULT_MOUNT_DIRS="${HOME}/code"

# Resolve the container image from distro + release.
#
# Known distros map to their official toolbox/base image at the host's release.
# A distro we don't recognise directly is mapped to a base via its os-release
# ID_LIKE (resolve_image_from_like): derivatives such as Mint/Pop!_OS/Manjaro
# go to their parent, and any RHEL-family clone (Rocky, AlmaLinux, Oracle, …)
# defaults to Rocky Linux — a binary-compatible image, unlike Fedora. Anything
# still unrecognised falls back to Fedora's toolbox image.
resolve_image() {
    local distro="${1:-$HOST_ID}"
    local release="${2:-$HOST_VERSION_ID}"
    case "$distro" in
        fedora)              echo "registry.fedoraproject.org/fedora-toolbox:${release}" ;;
        rhel)                echo "registry.access.redhat.com/ubi${release%%.*}/toolbox:${release}" ;;
        centos)              echo "quay.io/centos/centos:stream${release%%.*}" ;;
        rocky)               echo "docker.io/library/rockylinux:${release%%.*}" ;;
        ubuntu)              echo "docker.io/library/ubuntu:${release}" ;;
        debian)              echo "docker.io/library/debian:${release%%.*}" ;;
        arch)                echo "docker.io/library/archlinux:latest" ;;
        opensuse-leap)       echo "registry.opensuse.org/opensuse/leap:${release}" ;;
        opensuse-tumbleweed) echo "registry.opensuse.org/opensuse/tumbleweed:latest" ;;
        *)                   resolve_image_from_like "$release" ;;
    esac
}

# Map a distro we don't handle directly to a base image via os-release ID_LIKE.
# Non-RHEL derivative versions rarely line up with the base's tags, so those are
# pulled at :latest; RHEL-family clones share RHEL's major versioning, so they
# map to Rocky Linux at the host's major version. Falls back to Fedora's toolbox
# image when ID_LIKE is empty or names nothing we recognise.
resolve_image_from_like() {
    local release="${1:-latest}"
    local like
    for like in $HOST_ID_LIKE; do
        case "$like" in
            ubuntu)        echo "docker.io/library/ubuntu:latest";                  return ;;
            debian)        echo "docker.io/library/debian:latest";                  return ;;
            arch)          echo "docker.io/library/archlinux:latest";               return ;;
            suse|opensuse) echo "registry.opensuse.org/opensuse/tumbleweed:latest"; return ;;
            rhel|centos)   echo "docker.io/library/rockylinux:${release%%.*}";      return ;;
            fedora)        echo "registry.fedoraproject.org/fedora-toolbox:latest"; return ;;
        esac
    done
    echo "registry.fedoraproject.org/fedora-toolbox:latest"
}

# Resolve the default container name from distro + release
resolve_name() {
    local distro="${1:-$HOST_ID}"
    local release="${2:-$HOST_VERSION_ID}"
    echo "${distro}-toolbox-${release}"
}

# ---------------------------------------------------------------------------
# Configuration file
# ---------------------------------------------------------------------------
# Settings resolve by precedence:
#   CLI flags  >  environment variables  >  config file  >  built-in defaults
# The config file is a simple "key = value" file (see the "Configuration file"
# section of --help for the keys). Its location is $TOOLBOXER_CONFIG, else
# $XDG_CONFIG_HOME/toolboxer/config, else ~/.config/toolboxer/config.

# Capture env values before defaults/config fill them in, so the precedence
# above can be applied. `=""` here would clobber what the user exported.
env_mount_dirs="${MOUNT_DIRS:-}"
env_container_name="${CONTAINER_NAME:-}"
env_image="${IMAGE:-}"

# Values read from the config file (empty/false until load_config runs).
config_mounts=()
config_ai_agents=""
config_assumeyes=""
config_privileged=""
config_isolated=""
config_image=""
config_distro=""
config_release=""
config_container_name=""
config_authfile=""
config_provision_script=""

CONFIG_FILE="${TOOLBOXER_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/toolboxer/config}"

# Expand a leading ~ or ~/ to $HOME in a config value (the shell does not do
# tilde expansion on text read from a file). The tilde is kept in $t so it
# isn't written as a quoted ~ (SC2088) — matching it literally is intentional.
expand_tilde() {
    local t='~'
    case "$1" in
        "$t"|"$t/"*) printf '%s\n' "$HOME${1#"$t"}" ;;
        *)           printf '%s\n' "$1" ;;
    esac
}

# Normalise a boolean config value to "true"/"false"; warn and use false on
# anything unrecognised.
parse_bool() {
    case "${1,,}" in
        true|yes|on|1)     printf 'true\n' ;;
        false|no|off|0|"") printf 'false\n' ;;
        *) echo "Warning: invalid boolean '$1' in $CONFIG_FILE (use true/false)" >&2
           printf 'false\n' ;;
    esac
}

# Read CONFIG_FILE (if present) into the config_* variables. Format: one
# "key = value" per line; '#' starts a comment; blank lines are ignored;
# "key value" (no '=') is also accepted. The 'mount' key may be repeated and/or
# comma-separated. Unknown keys and bad booleans warn but don't abort.
load_config() {
    [[ -f "$CONFIG_FILE" ]] || return 0

    local lineno=0 line key value oldifs m
    local -a parts
    while IFS= read -r line || [[ -n "$line" ]]; do
        lineno=$((lineno + 1))
        line="${line%%#*}"                            # strip comments
        line="${line#"${line%%[![:space:]]*}"}"       # trim leading space
        line="${line%"${line##*[![:space:]]}"}"       # trim trailing space
        [[ -z "$line" ]] && continue

        if [[ "$line" == *=* ]]; then
            key="${line%%=*}"
            value="${line#*=}"
        else                                          # allow "key value"
            key="${line%%[[:space:]]*}"
            value="${line#"$key"}"
        fi
        key="${key#"${key%%[![:space:]]*}"}";        key="${key%"${key##*[![:space:]]}"}"
        value="${value#"${value%%[![:space:]]*}"}";  value="${value%"${value##*[![:space:]]}"}"
        key="${key//-/_}"; key="${key,,}"

        case "$key" in
            mount|mount_dirs)
                # Comma separates several mounts; ':' is reserved for src:dest
                # (see add_mount_spec). The key may also just be repeated.
                oldifs="$IFS"; IFS=","; read -ra parts <<< "$value"; IFS="$oldifs"
                for m in "${parts[@]}"; do
                    m="${m#"${m%%[![:space:]]*}"}"; m="${m%"${m##*[![:space:]]}"}"
                    [[ -n "$m" ]] && config_mounts+=("$m")
                done
                ;;
            ai_agents)                config_ai_agents="$(parse_bool "$value")" ;;
            assumeyes|assume_yes)     config_assumeyes="$(parse_bool "$value")" ;;
            privileged)               config_privileged="$(parse_bool "$value")" ;;
            isolated)                 config_isolated="$(parse_bool "$value")" ;;
            image)                    config_image="$value" ;;
            distro)                   config_distro="$value" ;;
            release)                  config_release="$value" ;;
            container_name|container) config_container_name="$value" ;;
            authfile)                 config_authfile="$(expand_tilde "$value")" ;;
            provision_script|provision) config_provision_script="$(expand_tilde "$value")" ;;
            "")                       : ;;
            *) echo "Warning: unknown config key '$key' in $CONFIG_FILE (line $lineno)" >&2 ;;
        esac
    done < "$CONFIG_FILE"
}

load_config

# Seed the working variables by precedence (CLI flags, parsed later, win over
# all of these). The mounts and the on/off modes are resolved after parsing by
# resolve_mount_dirs / resolve_modes below.
CONTAINER_NAME="${env_container_name:-$config_container_name}"
IMAGE="${env_image:-$config_image}"
DISTRO="$config_distro"
RELEASE="$config_release"
AUTHFILE="$config_authfile"
PRESERVE_FDS=""

# Optional provision script, run once inside a new container on first start (and
# on demand via 'provision'). Precedence: $TOOLBOXER_PROVISION > config
# 'provision_script' > a provision.sh next to the config file. Missing = skipped.
PROVISION_SCRIPT="$(expand_tilde "${TOOLBOXER_PROVISION:-${config_provision_script:-${CONFIG_FILE%/*}/provision.sh}}")"

# Set by finalize_names: true when the user identified a specific container (by
# name, or by choosing a distro/release). When pinned, resolve_container must
# not silently fall back to "the only existing container".
container_pinned=false

# Resolved mounts, one canonical "src:dest" spec per element (bare paths are
# stored as "src:src"). Populated by resolve_mount_dirs.
MOUNT_SPECS=()

# Append a mount spec to MOUNT_SPECS: "src" (same path) or "src:dest" (custom
# target), like podman -v. Leading ~ expanded on each side; stored as "src:dest".
add_mount_spec() {
    local spec="$1" src dest
    if [[ "$spec" == *:* ]]; then
        src="$(expand_tilde "${spec%%:*}")"
        dest="$(expand_tilde "${spec#*:}")"
    else
        src="$(expand_tilde "$spec")"
        dest="$src"
    fi
    if [[ -z "$src" || -z "$dest" ]]; then
        echo "Warning: ignoring invalid mount '$spec' (expected src or src:dest)" >&2
        return
    fi
    MOUNT_SPECS+=("$src:$dest")
}

# Split a comma-separated list of specs (the env var / a config value) and add
# each. Whitespace around a spec is trimmed.
add_mount_list() {
    local oldifs="$IFS" item
    local -a items
    IFS=","; read -ra items <<< "$1"; IFS="$oldifs"
    for item in "${items[@]}"; do
        item="${item#"${item%%[![:space:]]*}"}"; item="${item%"${item##*[![:space:]]}"}"
        [[ -n "$item" ]] && add_mount_spec "$item"
    done
}

# Resolve the mounts by precedence: CLI -m/--mount > $MOUNT_DIRS env >
# config-file mount(s) > built-in default. Each -m and each config value is one
# spec; the env var and config values may hold a comma-separated list. Re-run
# after each parsing pass.
resolve_mount_dirs() {
    local d
    MOUNT_SPECS=()
    if [[ ${#cli_mounts[@]} -gt 0 ]]; then
        for d in "${cli_mounts[@]}"; do add_mount_spec "$d"; done
    elif [[ -n "$env_mount_dirs" ]]; then
        add_mount_list "$env_mount_dirs"
    elif [[ ${#config_mounts[@]} -gt 0 ]]; then
        for d in "${config_mounts[@]}"; do add_mount_spec "$d"; done
    fi
    # Fall back to the default if nothing valid was given.
    if [[ ${#MOUNT_SPECS[@]} -eq 0 ]]; then
        add_mount_spec "$DEFAULT_MOUNT_DIRS"
    fi
}

# Split a canonical "src:dest" spec into _MOUNT_SRC / _MOUNT_DEST on the first
# colon (paths containing ':' are not supported, as with podman -v).
parse_mount_spec() {
    _MOUNT_SRC="${1%%:*}"
    _MOUNT_DEST="${1#*:}"
}

# Display form — collapse a "src:src" spec back to a bare path.
format_mount() {
    parse_mount_spec "$1"
    if [[ "$_MOUNT_SRC" == "$_MOUNT_DEST" ]]; then
        printf '%s' "$_MOUNT_SRC"
    else
        printf '%s:%s' "$_MOUNT_SRC" "$_MOUNT_DEST"
    fi
}

# Resolve the on/off modes by precedence: an explicit CLI flag (including the
# --no-* negations) > config file > off. For the mutually exclusive
# privileged/isolated pair, an explicit CLI choice of one suppresses the other
# inherited from the config file.
resolve_modes() {
    if [[ -n "$cli_ai_agents" ]]; then copy_ai_agents="$cli_ai_agents"
    else copy_ai_agents="${config_ai_agents:-false}"; fi

    if [[ -n "$cli_assumeyes" ]]; then assume_yes="$cli_assumeyes"
    else assume_yes="${config_assumeyes:-false}"; fi

    # Both chosen explicitly on the CLI is contradictory.
    if [[ "$cli_privileged" == true && "$cli_isolated" == true ]]; then
        echo "Error: --privileged and --isolated are mutually exclusive"
        exit 1
    fi

    if [[ -n "$cli_isolated" ]]; then
        isolated="$cli_isolated"
    elif [[ "$cli_privileged" == true ]]; then
        isolated=false                    # CLI chose privileged → not isolated
    else
        isolated="${config_isolated:-false}"
    fi

    if [[ -n "$cli_privileged" ]]; then
        privileged="$cli_privileged"
    elif [[ "$cli_isolated" == true ]]; then
        privileged=false                  # CLI chose isolated → not privileged
    else
        privileged="${config_privileged:-false}"
    fi

    # Catch a config file that enables both.
    if [[ "$privileged" == true && "$isolated" == true ]]; then
        echo "Error: privileged and isolated are mutually exclusive (check $CONFIG_FILE)"
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
toolboxer — a restricted, drop-in replacement for toolbox.

Usage: $prog [global options] <command> [command options] [args...]

Creates Podman development containers that mount only the directories you
choose, instead of your entire home directory:
  * Only selected directories are mounted (read-write)
  * Host integration (X11, Wayland, D-Bus, SSH agent, DNS, etc.) is seamless
  * A matching user with passwordless sudo is created inside the container
  * Uses --userns=keep-id so your UID/GID stay the same inside

Running '$prog' with no command defaults to 'enter'.

Commands:
  create [CONTAINER]      Create the container
  enter  [CONTAINER]      Enter the container (starts it if stopped, offers to create)
  run <cmd> [args...]     Run a single command inside the container
  list                    List toolboxer containers and/or images
  stop   [CONTAINER]      Stop the container
  rm     [CONTAINER...]   Remove the container(s)
  rmi    <IMAGE...>       Remove toolboxer image(s)
  config                  Show the effective configuration (config file + flags)
  provision [CONTAINER]   Re-run the provision script in a container
  help                    Show this help

Global options (must come before the command):
  -m, --mount SPEC        Mount a directory (read-write) into the container.
                          SPEC is DIR (mounted at the same path) or SRC:DEST
                          (mounted at a custom target), like podman -v. Repeat
                          the flag once per mount. This replaces the default
                          mount ($DEFAULT_MOUNT_DIRS) rather than adding to it.
  -A, --ai-agents         Also mount the config of any AI agent CLIs found in
                          your home (Claude Code, Codex, Gemini, Aider, …) so
                          they run inside the container with your host login.
  -y, --assumeyes         Assume yes to prompts (e.g. auto-create on 'enter').
      --privileged        Run the container privileged (needed to run podman or
                          docker inside it). Reduces isolation; off by default.
      --isolated          Hardened sandbox: SELinux-confined, only your mounts,
                          private namespaces, no host integration — for running
                          untrusted code. Incompatible with --privileged.
  -h, --help              Show this help

  Each of -A/-y/--privileged/--isolated has a --no-... form (--no-ai-agents,
  --no-assumeyes, --no-privileged, --no-isolated) to switch it off for one run
  when it is enabled by default in the config file.

Each command has its own options too — see '$prog <command> --help'.

Mounting additional directories:
  By default only $DEFAULT_MOUNT_DIRS is mounted. Pass -m/--mount once per
  directory you want available inside the container (the first one becomes the
  working directory on 'enter'). Each mount is DIR or SRC:DEST (a custom target
  path inside the container, like podman -v):

    $prog -m ~/code -m ~/documents create
    $prog create -m ~/code -m ~/work/project:/project   # custom target path

  Or set MOUNT_DIRS to a comma-separated list (CLI flags override it):

    MOUNT_DIRS=~/code,~/documents:/docs $prog create

Environment variables (override the config file, but not CLI flags):
  CONTAINER_NAME          Default container name
  IMAGE                   Image to use (e.g. fedora:41)
  MOUNT_DIRS              Comma-separated list of mounts (DIR or SRC:DEST each)

Configuration file (lowest priority — env vars and CLI flags override it):
  Set defaults in a "key = value" file at \$TOOLBOXER_CONFIG, else
  \${XDG_CONFIG_HOME:-~/.config}/toolboxer/config. Keys (all optional):
  mount (DIR or SRC:DEST; repeatable or comma-separated), ai_agents, assumeyes,
  privileged, isolated, image, distro, release, container_name, authfile,
  provision_script. Booleans take true/false. '#' starts a comment. Example:

    mount = ~/code
    mount = ~/data:/data
    ai_agents = true
    privileged = true

Examples:
  $prog                                # enter the default container
  $prog create                         # create the default container
  $prog -m ~/code -m ~/docs create     # create, mounting two directories
  $prog --ai-agents create             # create, sharing your AI agent logins
  $prog create --distro ubuntu --release 24.04
  $prog create --image fedora:41 my-project
  $prog enter my-project               # enter a named container
  $prog run make test                  # run a command in the container
  $prog list --containers              # list only containers
  $prog rm --all --force               # remove every toolboxer container
EOF
    exit "${1:-1}"
}

usage_create() {
    cat <<EOF
Usage: $prog create [options] [CONTAINER]

Create a new toolboxer container. If CONTAINER is omitted, the name is derived
from the distro and release (e.g. ${HOST_ID}-toolbox-${HOST_VERSION_ID}).

Options:
  -d, --distro DISTRO   Base distro: fedora, rhel, centos, rocky, ubuntu, debian,
                        arch, opensuse-leap, opensuse-tumbleweed
                        (default: host distro, $HOST_ID; incompatible with --image)
  -r, --release RELEASE Distro release/version
                        (default: host release, $HOST_VERSION_ID; incompatible with --image)
  -i, --image NAME      Use a custom image (incompatible with --distro/--release)
      --authfile FILE   Registry credentials file for pulling the image
  -m, --mount SPEC      Mount a directory (read-write); SPEC is DIR or SRC:DEST
                        (custom target, like podman -v). Repeat once per mount.
                        Replaces the default mount ($DEFAULT_MOUNT_DIRS).
                        The first mount's target becomes the working directory.
  -A, --ai-agents       Also mount the config/data dirs of AI agent CLIs found
                        in your home (Claude Code, Codex, Gemini, Aider, Goose,
                        OpenCode, …) at the same paths, so they run inside the
                        container using your existing host login/sessions. Only
                        dirs that exist are mounted; the agent CLI itself must
                        be installed in the container.
      --privileged      Run the container privileged (needed to run podman or
                        docker inside it). Reduces isolation; off by default.
      --isolated        Hardened sandbox: SELinux-confined, only your mounts
                        (relabeled), private namespaces, no host integration
                        (no GUI, host DNS, or nested podman). For untrusted
                        code. Incompatible with --privileged.
  -h, --help            Show this help

  -A/--privileged/--isolated each have a --no-... form (--no-ai-agents,
  --no-privileged, --no-isolated) to switch off a config-file default.

Examples:
  $prog create
  $prog create -m ~/code -m ~/documents
  $prog create --ai-agents
  $prog create --distro ubuntu --release 24.04 ubuntu-dev
  $prog create --image fedora:41
EOF
    exit "${1:-1}"
}

usage_enter() {
    cat <<EOF
Usage: $prog enter [options] [CONTAINER]

Enter a toolboxer container, starting it if stopped. If no container is named,
the default is used; if exactly one toolboxer container exists, it is chosen
automatically. If none exist, you are offered the chance to create one.

To mount extra directories when creating on demand, pass -m/--mount as a global
option before 'enter' (e.g. '$prog -m ~/code enter').

Options:
  -d, --distro DISTRO   Enter the container for a different distro
                        (fedora, rhel, centos, rocky, ubuntu, debian, arch, opensuse-*)
  -r, --release RELEASE Enter the container for a different release
  -h, --help            Show this help

Examples:
  $prog enter
  $prog enter my-project
  $prog enter --distro ubuntu --release 24.04
EOF
    exit "${1:-1}"
}

usage_run() {
    cat <<EOF
Usage: $prog run [options] [--] COMMAND [ARGS...]

Run a single command inside a toolboxer container, then exit. The container is
started first if it is stopped. Use '--' before COMMAND if its arguments would
otherwise be mistaken for run's own options.

Options:
  -c, --container NAME  Run in a specific container (default: the resolved container)
  -d, --distro DISTRO   Run in the container for a different distro
                        (fedora, rhel, centos, rocky, ubuntu, debian, arch, opensuse-*)
  -r, --release RELEASE Run in the container for a different release
      --preserve-fds N  Pass down N extra inherited file descriptors
  -h, --help            Show this help

Examples:
  $prog run make test
  $prog run --container my-project gcc -o hello hello.c
  $prog run -- ls -la
EOF
    exit "${1:-1}"
}

usage_list() {
    cat <<EOF
Usage: $prog list [options]

List toolboxer containers and images. With no options, both are shown.

Options:
  -c, --containers      Show only containers
  -i, --images          Show only images
  -h, --help            Show this help

Examples:
  $prog list
  $prog list --containers
  $prog list --images
EOF
    exit "${1:-1}"
}

usage_rm() {
    cat <<EOF
Usage: $prog rm [options] [CONTAINER...]

Remove one or more toolboxer containers. With no names and no --all, the
container is resolved the same way as 'create' — from --distro/--release (or
the host defaults) — so you can remove a container without typing its full
name. Running containers need --force.

Options:
  -a, --all             Remove all toolboxer containers
  -f, --force           Force removal of running containers
  -d, --distro DISTRO   Remove the container for a different distro
  -r, --release RELEASE Remove the container for a different release
  -h, --help            Show this help

Examples:
  $prog rm
  $prog rm my-project another-project
  $prog rm -r 44                  # removes the fedora-toolbox-44 container
  $prog rm --all --force
EOF
    exit "${1:-1}"
}

usage_rmi() {
    cat <<EOF
Usage: $prog rmi [options] <IMAGE...>

Remove one or more toolbox images. Specify image name(s) or use --all.

Options:
  -a, --all             Remove all toolbox images
  -f, --force           Force removal (removes dependent containers too)
  -h, --help            Show this help

Examples:
  $prog rmi fedora-toolbox:41
  $prog rmi --all
  $prog rmi --all --force
EOF
    exit "${1:-1}"
}

usage_stop() {
    cat <<EOF
Usage: $prog stop [options] [CONTAINER]

Stop a running toolboxer container. If no container is named, it is resolved
from --distro/--release (or the host defaults); if none of those match and only
one toolboxer container exists, that one is stopped.

Options:
  -d, --distro DISTRO   Stop the container for a different distro
  -r, --release RELEASE Stop the container for a different release
  -h, --help            Show this help

Examples:
  $prog stop
  $prog stop my-project
  $prog stop -r 44                # stops the fedora-toolbox-44 container
EOF
    exit "${1:-1}"
}

usage_config() {
    cat <<EOF
Usage: $prog config

Show the effective configuration: the config file location and the settings as
resolved from defaults, the config file, environment variables, and any global
flags given before 'config'. Read-only — it changes nothing.

Examples:
  $prog config
  $prog --privileged config       # preview with a flag applied
EOF
    exit "${1:-1}"
}

usage_provision() {
    cat <<EOF
Usage: $prog provision [CONTAINER]

Run the provision script inside CONTAINER (resolved like 'enter' from -d/-r or
the name). New containers are provisioned automatically on first start; use this
to re-run after editing the script, or to provision an older container.

The script is read from \$TOOLBOXER_PROVISION, else 'provision_script' in the
config file, else a provision.sh next to it. It runs as you (with passwordless
sudo) and is executed with bash. For anything heavy or that must be fast and
reproducible, build a custom image and use it with -i/--image instead.

Options:
  -d, --distro DISTRO   Resolve the container by distro
  -r, --release RELEASE Resolve the container by release
  -h, --help            Show this help

Examples:
  $prog provision
  $prog provision -d ubuntu -r 24.04
EOF
    exit "${1:-1}"
}

# ---------------------------------------------------------------------------
# Parse global options (only -m/--mount and -h/--help before the command)
# ---------------------------------------------------------------------------

cli_mounts=()
# Tri-state: "" = not given on the CLI (fall back to the config file), else the
# explicit choice. resolve_modes turns these into the final booleans below.
cli_ai_agents=""
cli_assumeyes=""
cli_privileged=""
cli_isolated=""
copy_ai_agents=false
assume_yes=false
privileged=false
isolated=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -m|--mount)       cli_mounts+=("$2");   shift 2 ;;
        -A|--ai-agents)   cli_ai_agents=true;   shift ;;
        --no-ai-agents)   cli_ai_agents=false;  shift ;;
        -y|--assumeyes)   cli_assumeyes=true;   shift ;;
        --no-assumeyes)   cli_assumeyes=false;  shift ;;
        --privileged)     cli_privileged=true;  shift ;;
        --no-privileged)  cli_privileged=false; shift ;;
        --isolated)       cli_isolated=true;    shift ;;
        --no-isolated)    cli_isolated=false;   shift ;;
        -h|--help)        usage 0 ;;
        -*)               echo "Unknown option: $1"; usage ;;
        *)                break ;;
    esac
done

resolve_modes
resolve_mount_dirs

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

build_volume_args() {
    local relabel="${1:-}"   # SELinux relabel suffix ("z"), or empty
    local args=() opt="" spec
    [[ -n "$relabel" ]] && opt=":$relabel"
    for spec in "${MOUNT_SPECS[@]}"; do
        parse_mount_spec "$spec"
        mkdir -p "$_MOUNT_SRC"
        # By default no SELinux relabel: the container runs with label=disable,
        # so :z would be pointless and fails on any file in the mount owned by
        # another user. --isolated runs confined and passes "z" to relabel.
        args+=(--volume "$_MOUNT_SRC:$_MOUNT_DEST$opt")
    done
    printf '%s\n' "${args[@]}"
}

build_host_integration_args() {
    local args=()

    # NB: /etc/hosts is deliberately NOT bind-mounted. Podman generates its own
    # (merging the host's entries by default) and we add a self-mapping for the
    # container hostname via --add-host at create time. Bind-mounting the host's
    # /etc/hosts read-only would clobber that self-mapping, so resolving the
    # container's own hostname falls through to DNS and stalls — which shows up
    # as slow 'sudo' (sudo resolves the local hostname on every call).
    local -a host_configs=(
        /etc/resolv.conf
        /etc/host.conf
        /etc/hostname
        /etc/localtime
        /etc/timezone
        /etc/machine-id
    )
    for f in "${host_configs[@]}"; do
        [[ -e "$f" ]] && args+=(--volume "$f:$f:ro")
    done

    if [[ -d /tmp/.X11-unix ]]; then
        args+=(--volume "/tmp/.X11-unix:/tmp/.X11-unix:ro")
    fi

    local xdg_runtime="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    if [[ -d "$xdg_runtime" ]]; then
        args+=(--volume "$xdg_runtime:$xdg_runtime")
        # Shadow podman's runtime state with empty container-local volumes so a
        # nested rootless podman keeps its runroot and pause file to itself
        # rather than clobbering the host's (see README). The GUI sockets at the
        # top level of XDG_RUNTIME_DIR are unaffected. Anonymous volumes, not
        # tmpfs: an older crun (e.g. on Fedora 43) rejects a tmpfs mounted
        # inside a bind mount with "crun: read: Invalid argument".
        args+=(--volume "$xdg_runtime/containers")
        args+=(--volume "$xdg_runtime/libpod")
    fi

    if [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
        local dbus_path="${DBUS_SESSION_BUS_ADDRESS#unix:path=}"
        if [[ "$dbus_path" != "$DBUS_SESSION_BUS_ADDRESS" && -e "$dbus_path" ]]; then
            args+=(--volume "$dbus_path:$dbus_path")
        fi
    fi

    if [[ -n "${SSH_AUTH_SOCK:-}" && -e "$SSH_AUTH_SOCK" ]]; then
        args+=(--volume "$SSH_AUTH_SOCK:$SSH_AUTH_SOCK")
    fi

    if [[ -d /run/systemd/journal ]]; then
        args+=(--volume "/run/systemd/journal:/run/systemd/journal:ro")
    fi

    if [[ -d /run/udev/data ]]; then
        args+=(--volume "/run/udev/data:/run/udev/data:ro")
    fi

    printf '%s\n' "${args[@]}"
}

build_env_args() {
    local args=()

    [[ -n "${DISPLAY:-}" ]]                && args+=(--env "DISPLAY=$DISPLAY")
    [[ -n "${WAYLAND_DISPLAY:-}" ]]        && args+=(--env "WAYLAND_DISPLAY=$WAYLAND_DISPLAY")
    [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]] && args+=(--env "DBUS_SESSION_BUS_ADDRESS=$DBUS_SESSION_BUS_ADDRESS")
    [[ -n "${SSH_AUTH_SOCK:-}" ]]          && args+=(--env "SSH_AUTH_SOCK=$SSH_AUTH_SOCK")
    [[ -n "${TERM:-}" ]]                   && args+=(--env "TERM=$TERM")
    [[ -n "${LANG:-}" ]]                   && args+=(--env "LANG=$LANG")

    local xdg_runtime="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    args+=(--env "XDG_RUNTIME_DIR=$xdg_runtime")

    printf '%s\n' "${args[@]}"
}

# Home-relative config/data paths for popular AI agent CLIs. With --ai-agents,
# any that exist on the host are bind-mounted into the container at the same
# path (see README). Missing paths are skipped, so extra candidates are safe.
AI_AGENT_PATHS=(
    .claude .claude.json                        # Claude Code (Anthropic)
    .codex                                      # OpenAI Codex
    .gemini                                     # Gemini CLI (Google)
    .qwen                                       # Qwen Code
    .cursor                                     # Cursor agent
    .grok .config/grok                          # Grok CLI (xAI)
    .continue                                   # Continue
    .config/github-copilot .copilot             # GitHub Copilot CLI
    .config/goose .local/share/goose            # Goose (Block)
    .config/opencode .local/share/opencode      # OpenCode
    .config/crush .local/share/crush            # Crush (Charm)
    .aider.conf.yml .aider.model.settings.yml .aider.model.metadata.json .config/aider  # Aider
    .config/io.datasette.llm                    # llm (Datasette)
    .config/shell_gpt                           # Shell-GPT (sgpt)
    .config/open-interpreter                    # Open Interpreter
)

build_ai_agent_args() {
    local relabel="${1:-}"   # SELinux relabel suffix ("z"), or empty
    local args=() p opt=""
    [[ -n "$relabel" ]] && opt=":$relabel"
    for p in "${AI_AGENT_PATHS[@]}"; do
        # No SELinux relabel by default (label=disable); --isolated passes "z".
        [[ -e "$HOME/$p" ]] && args+=(--volume "$HOME/$p:$HOME/$p$opt")
    done
    [[ ${#args[@]} -gt 0 ]] && printf '%s\n' "${args[@]}"
}

# The agent paths that were actually found, for display.
found_ai_agents() {
    local p found=()
    for p in "${AI_AGENT_PATHS[@]}"; do
        [[ -e "$HOME/$p" ]] && found+=("$p")
    done
    printf '%s\n' "${found[*]}"
}

default_workdir() {
    # workdir = where the first mount lands (its dest).
    parse_mount_spec "${MOUNT_SPECS[0]}"
    echo "$_MOUNT_DEST"
}

setup_user_in_container() {
    local cname="$1"
    local uid gid user_name user_shell user_home
    uid="$(id -u)"
    gid="$(id -g)"
    user_name="$(id -un)"
    # The host's login shell isn't guaranteed to exist in the container, so
    # default to bash (always present in toolbox-style images).
    user_shell="/bin/bash"
    user_home="$HOME"

    # Make the in-container user match the host (same UID/GID and name) so file
    # ownership lines up and the sudoers entry below applies. A generic image may
    # ship a stock account already occupying the host UID/GID — Ubuntu's
    # ubuntu:1000 is the common case — so rename it rather than failing to add
    # ours (a plain useradd -u would collide on the in-use UID).
    podman exec --user root -i "$cname" bash -s -- \
        "$uid" "$gid" "$user_name" "$user_home" "$user_shell" <<'SETUP' || true
set -e
uid="$1"; gid="$2"; user_name="$3"; user_home="$4"; user_shell="$5"

# Group: rename whatever holds the host GID to our name, else create it.
existing_group="$(getent group "$gid" | cut -d: -f1 || true)"
if [ -n "$existing_group" ]; then
    [ "$existing_group" != "$user_name" ] && groupmod -n "$user_name" "$existing_group"
elif ! getent group "$user_name" >/dev/null 2>&1; then
    groupadd -g "$gid" "$user_name"
fi

# User: rename whatever holds the host UID to our name (fixing home/shell/group),
# else create it. usermod -l renames the colliding account (e.g. ubuntu).
existing_user="$(getent passwd "$uid" | cut -d: -f1 || true)"
if [ -n "$existing_user" ]; then
    if [ "$existing_user" != "$user_name" ]; then
        usermod -l "$user_name" -d "$user_home" -s "$user_shell" -g "$gid" "$existing_user"
    else
        usermod -d "$user_home" -s "$user_shell" -g "$gid" "$user_name"
    fi
elif ! id "$user_name" >/dev/null 2>&1; then
    useradd -u "$uid" -g "$gid" -d "$user_home" -s "$user_shell" -M "$user_name"
fi
SETUP

    # Give the user a writable home. When mounts sit under $HOME (the default
    # ~/code), podman auto-creates $HOME as a root-owned mount parent, so the
    # user can't write to it. Create it if missing and hand it over -- not
    # recursive, so the mounted dirs inside keep their own owners. Left empty by
    # design (no /etc/skel seeding): bring dotfiles via a mount or the provision
    # script, rather than us dropping files the user didn't ask for.
    podman exec --user root "$cname" mkdir -p "$user_home"
    podman exec --user root "$cname" chown "$uid:$gid" "$user_home"

    # Ensure sudo is installed — Fedora/RHEL toolbox images ship it, but the
    # generic ubuntu/arch images we support via --distro don't.
    podman exec --user root "$cname" bash -c '
        if command -v sudo >/dev/null 2>&1; then exit 0; fi
        if command -v dnf >/dev/null 2>&1; then
            dnf install -y sudo >/dev/null 2>&1
        elif command -v apt-get >/dev/null 2>&1; then
            apt-get update >/dev/null 2>&1 && DEBIAN_FRONTEND=noninteractive apt-get install -y sudo >/dev/null 2>&1
        elif command -v pacman >/dev/null 2>&1; then
            pacman -Sy --noconfirm sudo >/dev/null 2>&1
        elif command -v zypper >/dev/null 2>&1; then
            zypper --non-interactive install sudo >/dev/null 2>&1
        fi
    ' || true

    # Grant passwordless sudo. Validate the drop-in with visudo so a malformed
    # file surfaces here instead of silently falling back to a password prompt.
    podman exec --user root "$cname" mkdir -p /etc/sudoers.d
    podman exec --user root "$cname" bash -c "echo '$user_name ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/$user_name && chmod 440 /etc/sudoers.d/$user_name"
    if ! podman exec --user root "$cname" visudo -cf "/etc/sudoers.d/$user_name" >/dev/null 2>&1; then
        echo "Warning: passwordless-sudo setup for '$user_name' did not validate; sudo may prompt for a password." >&2
    fi

    # Default the nested podman to host networking so it needs no /dev/net/tun
    # (see README). A drop-in merges with the image's own containers.conf.
    podman exec --user root "$cname" bash -c '
        mkdir -p /etc/containers/containers.conf.d
        cat > /etc/containers/containers.conf.d/90-toolboxer-nested.conf <<EOF
# Added by toolboxer: host networking for nested (podman-in-podman) containers
# so no /dev/net/tun is needed. Override per-container with e.g. --network pasta.
[containers]
netns="host"
EOF
    ' || true

    # Mark interactive shells with a magenta hexagon, like toolbox. The full
    # prompt is set (not prepended) so it survives the image's bashrc; a
    # mounted ~/.bashrc still overrides it.
    podman exec --user root -i "$cname" \
        tee /etc/profile.d/toolboxer.sh >/dev/null <<'PROFILE' || true
# Added by toolboxer: magenta hexagon prompt marker (like toolbox).
if [ -n "${PS1-}" ]; then
    PS1="\[\e[1;35m\]⬢\[\e[0m\] [\u@\h \W]\$ "
fi
PROFILE
}

# Run the provision script (if any) in the container as the host user, fed on
# stdin to bash — only bash is supported, the shebang is ignored. $2="required"
# turns a missing script into an error rather than a silent skip.
run_provision() {
    local cname="$1" required="${2:-}"
    if [[ ! -f "$PROVISION_SCRIPT" ]]; then
        if [[ "$required" == "required" ]]; then
            echo "Error: no provision script at '$PROVISION_SCRIPT'." >&2
            echo "Set 'provision_script' in $CONFIG_FILE or create that file." >&2
            exit 1
        fi
        return 0
    fi

    # Expose the container's actual distro/release (from its os-release) so the
    # script can pick a package manager without re-detecting it.
    local osrel cdistro="" crelease=""
    osrel="$(podman exec "$cname" sh -c '. /etc/os-release 2>/dev/null && printf "%s %s" "${ID:-}" "${VERSION_ID:-}"' 2>/dev/null)" || true
    read -r cdistro crelease <<< "$osrel" || true

    echo "Provisioning from $PROVISION_SCRIPT ..."
    # Run as the host user (passwordless sudo is available for privileged steps)
    # in the container's default working directory (a mounted, writable dir).
    podman exec --user "$(id -u):$(id -g)" -i \
        --env "TOOLBOXER_DISTRO=$cdistro" \
        --env "TOOLBOXER_RELEASE=$crelease" \
        "$cname" bash -s < "$PROVISION_SCRIPT"
}

ensure_exists() {
    podman container exists "$CONTAINER_NAME"
}

ensure_started() {
    local state
    state="$(podman inspect --format '{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || true)"

    if [[ "$state" == "running" ]]; then
        return 0
    fi

    # Container is created/stopped — start it. Keep stderr (only the success
    # output, the container name, goes to /dev/null) so a failure such as a
    # mount or file-ownership problem is visible instead of being swallowed,
    # and stop with a clear message rather than failing silently under set -e.
    if ! podman start "$CONTAINER_NAME" >/dev/null; then
        echo "Error: failed to start container '$CONTAINER_NAME' (see the podman error above)." >&2
        exit 1
    fi

    # The nested-podman runtime volumes (see build_host_integration_args) can
    # come up root-owned; hand them to our user so the nested podman can use
    # them.
    local xdg
    xdg="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    podman exec --user root "$CONTAINER_NAME" \
        chown "$(id -u):$(id -g)" "$xdg/containers" "$xdg/libpod" 2>/dev/null || true

    # Run user setup on first start (check if sudoers file exists)
    local user_name
    user_name="$(id -un)"
    if ! podman exec --user root "$CONTAINER_NAME" test -f "/etc/sudoers.d/$user_name" 2>/dev/null; then
        echo "Setting up user environment..."
        setup_user_in_container "$CONTAINER_NAME"
        # Provision once, after the user/sudo setup. Best-effort: a failure warns
        # but leaves the container usable.
        if ! run_provision "$CONTAINER_NAME"; then
            echo "Warning: provision script failed; the container is still usable." >&2
            echo "Re-run it after fixing the script with: $prog provision $CONTAINER_NAME" >&2
        fi
    fi
}

# Find the default container: use CONTAINER_NAME if set/exists, otherwise
# fall back to the only existing toolboxer container (if exactly one exists).
resolve_container() {
    if [[ -n "$CONTAINER_NAME" ]] && ensure_exists; then
        return 0
    fi

    # The user asked for a specific container (by name or distro/release) and it
    # does not exist — don't enter a different one. Let the caller create it.
    if [[ "$container_pinned" == true ]]; then
        return 1
    fi

    local containers
    containers="$(podman container list --all --filter 'label=toolboxer=true' --format '{{.Names}}' 2>/dev/null)"
    local count
    count="$(echo "$containers" | grep -c . 2>/dev/null || true)"

    if [[ "$count" -eq 1 ]]; then
        CONTAINER_NAME="$containers"
        echo "Using container '$CONTAINER_NAME'"
        return 0
    fi

    return 1
}

# Finalize CONTAINER_NAME and IMAGE from distro/release/env/defaults.
# CONTAINER_NAME/IMAGE are pre-seeded from the environment at the top of the
# script, so anything still empty here means: no CLI flag, no env value — use
# the distro/release default.
finalize_names() {
    # "Pinned" = the user named a container (flag/env/config) or chose a distro/
    # release. Captured before CONTAINER_NAME is defaulted below, so a bare
    # invocation (everything host-default) stays unpinned and may auto-fall-back.
    if [[ -n "$CONTAINER_NAME" || -n "$DISTRO" || -n "$RELEASE" ]]; then
        container_pinned=true
    else
        container_pinned=false
    fi
    if [[ -z "$CONTAINER_NAME" ]]; then
        CONTAINER_NAME="$(resolve_name "$DISTRO" "$RELEASE")"
    fi
    if [[ -z "$IMAGE" ]]; then
        IMAGE="$(resolve_image "$DISTRO" "$RELEASE")"
    fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd="${1:-}"
if [[ -z "$cmd" ]]; then
    cmd="enter"
else
    shift || true
fi

case "$cmd" in
    create)
        # Track which of image/distro/release the user gave on the CLI, so a CLI
        # choice can override the incompatible one when it only came from config.
        cli_image_set=false
        cli_distro_set=false
        cli_release_set=false
        # Parse create-specific flags
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -d|--distro)      DISTRO="$2";  cli_distro_set=true;  shift 2 ;;
                -i|--image)       IMAGE="$2";   cli_image_set=true;   shift 2 ;;
                -r|--release)     RELEASE="$2"; cli_release_set=true; shift 2 ;;
                -m|--mount)       cli_mounts+=("$2");   shift 2 ;;
                -A|--ai-agents)   cli_ai_agents=true;   shift ;;
                --no-ai-agents)   cli_ai_agents=false;  shift ;;
                --authfile)       AUTHFILE="$2"; shift 2 ;;
                --privileged)     cli_privileged=true;  shift ;;
                --no-privileged)  cli_privileged=false; shift ;;
                --isolated)       cli_isolated=true;    shift ;;
                --no-isolated)    cli_isolated=false;   shift ;;
                -h|--help)        usage_create 0 ;;
                -*)               echo "Unknown create option: $1"; usage_create ;;
                *)                CONTAINER_NAME="$1"; shift ;;
            esac
        done

        # A CLI --image overrides a distro/release that only came from the config
        # file (and vice versa) — the two cannot be combined.
        if [[ "$cli_image_set" == true ]]; then
            [[ "$cli_distro_set" == false ]] && DISTRO=""
            [[ "$cli_release_set" == false ]] && RELEASE=""
        elif [[ "$cli_distro_set" == true || "$cli_release_set" == true ]]; then
            IMAGE=""
        fi

        # --image is incompatible with --distro/--release
        if [[ -n "$IMAGE" && ( -n "$DISTRO" || -n "$RELEASE" ) ]]; then
            echo "Error: --image is incompatible with --distro and --release"
            exit 1
        fi

        # Re-resolve modes/mounts now that create's own flags are parsed.
        # (resolve_modes also rejects a privileged+isolated combination.)
        resolve_modes
        resolve_mount_dirs

        finalize_names

        if ensure_exists; then
            echo "Error: Container '$CONTAINER_NAME' already exists."
            echo "Remove it first with: $prog rm"
            exit 1
        fi

        mount_display=()
        for spec in "${MOUNT_SPECS[@]}"; do mount_display+=("$(format_mount "$spec")"); done
        echo "Creating restricted toolbox '$CONTAINER_NAME'"
        echo "Image: $IMAGE"
        echo "Mounting: ${mount_display[*]}"

        # Assemble the create flags by mode.
        #
        # default: toolbox-style — SELinux off for the container (label=disable),
        #   full host integration, host namespaces. --privileged additionally
        #   grants a nested rootless podman the caps it needs (sethostname,
        #   mounting /proc); see README.
        # --isolated: a hardened sandbox — SELinux-confined (no label=disable),
        #   private namespaces, no host integration, and the mounts relabeled
        #   with :z so the confined container can use them.
        relabel=""
        sec_args=()
        ns_args=()
        host_args=()
        env_args=()
        if [[ "$isolated" == true ]]; then
            relabel="z"
            [[ -n "${TERM:-}" ]] && env_args+=(--env "TERM=$TERM")
            [[ -n "${LANG:-}" ]] && env_args+=(--env "LANG=$LANG")
            echo "Isolation: confined (SELinux, private namespaces, no host integration)"
        else
            sec_args=(--security-opt label=disable)
            [[ "$privileged" == true ]] && sec_args+=(--privileged)
            ns_args=(--network host --ipc host --pid host)
            mapfile -t host_args < <(build_host_integration_args)
            mapfile -t env_args < <(build_env_args)
        fi
        mapfile -t vol_args < <(build_volume_args "$relabel")

        agent_args=()
        if [[ "$copy_ai_agents" == true ]]; then
            mapfile -t agent_args < <(build_ai_agent_args "$relabel")
            found_paths="$(found_ai_agents)"
            if [[ -n "$found_paths" ]]; then
                echo "AI agent config: $found_paths"
            else
                echo "AI agent config: none found in $HOME"
            fi
        fi

        # --authfile (toolbox-compatible): credentials for pulling the image.
        authfile_args=()
        [[ -n "$AUTHFILE" ]] && authfile_args=(--authfile "$AUTHFILE")

        # Run the idle PID 1 as root, not the host user: under --userns=keep-id
        # it otherwise owns the host account, so setup's usermod fails ("currently
        # used by process") and a colliding stock user (ubuntu:1000) never gets
        # renamed. run/enter still exec as the host user.
        podman create -it \
            --name "$CONTAINER_NAME" \
            --userns=keep-id \
            --user root \
            "${sec_args[@]}" \
            --hostname toolboxer \
            --add-host toolboxer:127.0.0.1 \
            "${ns_args[@]}" \
            "${vol_args[@]}" \
            "${host_args[@]}" \
            "${env_args[@]}" \
            "${agent_args[@]}" \
            "${authfile_args[@]}" \
            --workdir "$(default_workdir)" \
            --label "toolbox=true" \
            --label "toolboxer=true" \
            "$IMAGE" \
            sleep infinity

        echo "Restricted toolbox '$CONTAINER_NAME' created!"
        echo "Run '$prog enter' to start using it."
        ;;

    enter)
        # Parse enter-specific flags
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -d|--distro)  DISTRO="$2";  shift 2 ;;
                -r|--release) RELEASE="$2"; shift 2 ;;
                -h|--help)    usage_enter 0 ;;
                -*)           echo "Unknown enter option: $1"; usage_enter ;;
                *)            CONTAINER_NAME="$1"; shift ;;
            esac
        done

        finalize_names

        if ! resolve_container; then
            echo "Container '$CONTAINER_NAME' not found."
            if [[ "$assume_yes" == true ]]; then
                answer="y"
            else
                read -rp "Create container '$CONTAINER_NAME' now? [y/N] " answer
            fi
            if [[ "$answer" =~ ^[Yy] ]]; then
                # Build the re-invocation as an array so paths with spaces survive.
                reinvoke_args=()
                for d in "${cli_mounts[@]}"; do
                    reinvoke_args+=(-m "$d")
                done
                # Pass each mode explicitly (including the --no-* forms) so the
                # re-invoked 'create' — which re-reads the config file — cannot
                # derive a different value than we resolved here.
                if [[ "$copy_ai_agents" == true ]]; then
                    reinvoke_args+=(--ai-agents)
                else
                    reinvoke_args+=(--no-ai-agents)
                fi
                if [[ "$isolated" == true ]]; then
                    reinvoke_args+=(--isolated)
                elif [[ "$privileged" == true ]]; then
                    reinvoke_args+=(--privileged)
                else
                    reinvoke_args+=(--no-privileged --no-isolated)
                fi
                reinvoke_args+=(create)
                [[ -n "$DISTRO" ]] && reinvoke_args+=(--distro "$DISTRO")
                [[ -n "$RELEASE" ]] && reinvoke_args+=(--release "$RELEASE")
                reinvoke_args+=("$CONTAINER_NAME")
                "$0" "${reinvoke_args[@]}"
            else
                exit 1
            fi
        fi

        ensure_started
        exec podman exec -it \
            --user "$(id -u):$(id -g)" \
            --workdir "$(default_workdir)" \
            "$CONTAINER_NAME" \
            bash -l
        ;;

    run)
        # Parse run-specific flags
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--container) CONTAINER_NAME="$2"; shift 2 ;;
                -d|--distro)    DISTRO="$2";         shift 2 ;;
                -r|--release)   RELEASE="$2";        shift 2 ;;
                --preserve-fds) PRESERVE_FDS="$2";   shift 2 ;;
                -h|--help)      usage_run 0 ;;
                --)             shift; break ;;
                *)              break ;;
            esac
        done

        if [[ $# -eq 0 ]]; then
            echo "Error: 'run' requires a command."
            echo "Usage: $prog run <command> [args...]"
            exit 1
        fi

        finalize_names

        if ! resolve_container; then
            echo "Error: container '$CONTAINER_NAME' not found."
            echo "Create one first with: $prog create"
            exit 1
        fi
        ensure_started
        # --preserve-fds (toolbox-compatible): pass N extra inherited fds through.
        pfds_args=()
        [[ -n "$PRESERVE_FDS" ]] && pfds_args=(--preserve-fds "$PRESERVE_FDS")
        # Only allocate a TTY when interactive — a forced -t on a pipe makes
        # podman's PTY rewrite \n to \r\n and corrupt captured output. Keep -i
        # so stdin can still be piped in.
        run_tty=(-i)
        [[ -t 0 && -t 1 ]] && run_tty+=(-t)
        podman exec "${run_tty[@]}" \
            --user "$(id -u):$(id -g)" \
            --workdir "$(default_workdir)" \
            "${pfds_args[@]}" \
            "$CONTAINER_NAME" \
            "$@"
        ;;

    list)
        local_show_containers=true
        local_show_images=true
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--containers) local_show_images=false;     shift ;;
                -i|--images)     local_show_containers=false; shift ;;
                -h|--help)       usage_list 0 ;;
                *) echo "Unknown list option: $1"; usage_list ;;
            esac
        done

        if [[ "$local_show_images" == true ]]; then
            printf "%-14s %-45s %s\n" "IMAGE ID" "IMAGE NAME" "CREATED"
            while IFS=$'\t' read -r iid iname icreated; do
                printf "%-14s %-45s %s\n" "$iid" "$iname" "$icreated"
            done < <(podman image list --filter "reference=*toolbox*" --sort repository --format "{{.ID}}"$'\t'"{{.Repository}}:{{.Tag}}"$'\t'"{{.Created}}")
            echo
        fi
        if [[ "$local_show_containers" == true ]]; then
            printf "%-14s %-25s %-20s %-15s %s\n" "CONTAINER ID" "CONTAINER NAME" "CREATED" "STATUS" "IMAGE NAME"
            while IFS=$'\t' read -r cid cname ccreated cstatus cimage; do
                if [[ "$cstatus" == Up* ]] && [[ -t 1 ]]; then
                    printf "\033[32m%-14s %-25s %-20s %-15s %s\033[0m\n" "$cid" "$cname" "$ccreated" "$cstatus" "$cimage"
                else
                    printf "%-14s %-25s %-20s %-15s %s\n" "$cid" "$cname" "$ccreated" "$cstatus" "$cimage"
                fi
            done < <(podman container list --all --filter "label=toolboxer=true" --format "{{.ID}}\t{{.Names}}\t{{.CreatedHuman}}\t{{.Status}}\t{{.Image}}")
        fi
        ;;

    stop)
        # Parse stop-specific flags / positional container name
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -d|--distro)  DISTRO="$2";  shift 2 ;;
                -r|--release) RELEASE="$2"; shift 2 ;;
                -h|--help)    usage_stop 0 ;;
                -*)           echo "Unknown stop option: $1"; usage_stop ;;
                *)            CONTAINER_NAME="$1"; shift ;;
            esac
        done

        finalize_names

        if ! resolve_container; then
            echo "Error: Container '$CONTAINER_NAME' does not exist."
            exit 1
        fi
        podman stop "$CONTAINER_NAME" && echo "Container '$CONTAINER_NAME' stopped."
        ;;

    rm)
        local_all=false
        local_force=false
        local_containers=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -a|--all)     local_all=true;             shift ;;
                -f|--force)   local_force=true;           shift ;;
                -d|--distro)  DISTRO="$2";                shift 2 ;;
                -r|--release) RELEASE="$2";               shift 2 ;;
                -h|--help)    usage_rm 0 ;;
                -*)           echo "Unknown rm option: $1"; usage_rm ;;
                *)            local_containers+=("$1");   shift ;;
            esac
        done

        rm_flags=()
        [[ "$local_force" == true ]] && rm_flags+=(-f)

        if [[ "$local_all" == true ]]; then
            containers="$(podman container list --all --filter 'label=toolboxer=true' --format '{{.Names}}' 2>/dev/null)"
            if [[ -z "$containers" ]]; then
                echo "No toolboxer containers found."
                exit 0
            fi
            while IFS= read -r c; do
                if podman rm "${rm_flags[@]}" "$c" >/dev/null 2>&1; then
                    echo "Container '$c' removed."
                else
                    echo "Error: Could not remove '$c' (is it running? use --force)"
                fi
            done <<< "$containers"
        else
            # If specific containers were named, use those; otherwise use default
            if [[ ${#local_containers[@]} -eq 0 ]]; then
                finalize_names
                local_containers=("$CONTAINER_NAME")
            fi
            for cname in "${local_containers[@]}"; do
                if podman rm "${rm_flags[@]}" "$cname" >/dev/null 2>&1; then
                    echo "Container '$cname' removed."
                else
                    if podman container exists "$cname"; then
                        echo "Error: Could not remove '$cname' (is it running? use --force)"
                    else
                        echo "Container '$cname' not found."
                    fi
                fi
            done
        fi
        ;;

    rmi)
        local_all=false
        local_force=false
        local_images=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -a|--all)   local_all=true;          shift ;;
                -f|--force) local_force=true;         shift ;;
                -h|--help)  usage_rmi 0 ;;
                -*)         echo "Unknown rmi option: $1"; usage_rmi ;;
                *)          local_images+=("$1");     shift ;;
            esac
        done

        rmi_flags=()
        [[ "$local_force" == true ]] && rmi_flags+=(-f)

        if [[ "$local_all" == true ]]; then
            images="$(podman image list --filter 'reference=*toolbox*' --format '{{.Repository}}:{{.Tag}}' 2>/dev/null)"
            if [[ -z "$images" ]]; then
                echo "No toolbox images found."
                exit 0
            fi
            while IFS= read -r img; do
                if [[ "$local_force" == true ]]; then
                    deps="$(podman container list --all --filter "ancestor=$img" --filter 'label=toolboxer=true' --format '{{.Names}}' 2>/dev/null)"
                    if [[ -n "$deps" ]]; then
                        while IFS= read -r c; do
                            podman rm -f "$c" >/dev/null 2>&1 && echo "Container '$c' removed."
                        done <<< "$deps"
                    fi
                fi
                if podman rmi "${rmi_flags[@]}" "$img" >/dev/null 2>&1; then
                    echo "Image '$img' removed."
                else
                    echo "Error: Could not remove image '$img'"
                fi
            done <<< "$images"
        elif [[ ${#local_images[@]} -gt 0 ]]; then
            for img in "${local_images[@]}"; do
                if podman rmi "${rmi_flags[@]}" "$img" >/dev/null 2>&1; then
                    echo "Image '$img' removed."
                else
                    echo "Error: Could not remove image '$img'"
                fi
            done
        else
            echo "Error: Specify image name(s) or use --all"
            exit 1
        fi
        ;;

    config)
        # Show the effective configuration. Read-only — resolves nothing on the
        # host, just reports how settings combined from defaults, the config
        # file, env vars, and any global flags before 'config'.
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -h|--help)    usage_config 0 ;;
                -*)           echo "Unknown config option: $1"; usage_config ;;
                *)            echo "Unknown config argument: $1"; usage_config ;;
            esac
        done

        finalize_names
        mount_display=()
        for spec in "${MOUNT_SPECS[@]}"; do mount_display+=("$(format_mount "$spec")"); done

        if [[ -f "$CONFIG_FILE" ]]; then
            echo "Config file: $CONFIG_FILE (loaded)"
        else
            echo "Config file: $CONFIG_FILE (not found)"
        fi
        echo "Effective settings (config file < env vars < CLI flags):"
        printf '  %-11s %s\n' "mount"      "${mount_display[*]}"
        printf '  %-11s %s\n' "ai_agents"  "$copy_ai_agents"
        printf '  %-11s %s\n' "assumeyes"  "$assume_yes"
        printf '  %-11s %s\n' "privileged" "$privileged"
        printf '  %-11s %s\n' "isolated"   "$isolated"
        printf '  %-11s %s\n' "image"      "$IMAGE"
        printf '  %-11s %s\n' "container"  "$CONTAINER_NAME"
        if [[ -n "$DISTRO" ]]; then
            printf '  %-11s %s\n' "distro"  "$DISTRO"
        else
            printf '  %-11s %s\n' "distro"  "$HOST_ID (host default)"
        fi
        if [[ -n "$RELEASE" ]]; then
            printf '  %-11s %s\n' "release" "$RELEASE"
        else
            printf '  %-11s %s\n' "release" "$HOST_VERSION_ID (host default)"
        fi
        printf '  %-11s %s\n' "authfile"   "${AUTHFILE:-(none)}"
        if [[ -f "$PROVISION_SCRIPT" ]]; then
            printf '  %-11s %s\n' "provision" "$PROVISION_SCRIPT"
        else
            printf '  %-11s %s\n' "provision" "$PROVISION_SCRIPT (not found)"
        fi
        ;;

    provision)
        # On-demand re-run; first start provisions automatically (see usage_provision).
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -d|--distro)  DISTRO="$2";  shift 2 ;;
                -r|--release) RELEASE="$2"; shift 2 ;;
                -h|--help)    usage_provision 0 ;;
                -*)           echo "Unknown provision option: $1"; usage_provision ;;
                *)            CONTAINER_NAME="$1"; shift ;;
            esac
        done

        finalize_names
        if ! resolve_container; then
            echo "Error: container '$CONTAINER_NAME' not found."
            echo "Create one first with: $prog create"
            exit 1
        fi
        ensure_started
        run_provision "$CONTAINER_NAME" required
        ;;

    help)
        usage 0
        ;;

    *)
        echo "Unknown command: $cmd"
        usage
        ;;
esac
